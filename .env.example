# ════════════════════════════════════════════════════════════════════════════
# Fireworks.ai — powers all three agents (planner / critic / synthesizer),
# the dense embeddings (Qwen3-Embedding-8B → /v1/embeddings), and the reranker
# (Qwen3-Reranker-8B → /v1/rerank).
# ════════════════════════════════════════════════════════════════════════════
FIREWORKS_API_KEY=fw_
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ════════════════════════════════════════════════════════════════════════════
# Groq — vision model for query-time + ingestion-time VLM calls.
# Non-thinking (fast), OpenAI-compatible endpoint. Toggle USE_GROQ_VLM=false
# to fall back to Fireworks's multimodal model everywhere.
# ════════════════════════════════════════════════════════════════════════════
GROQ_API_KEY=gsk_your_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_VLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VLM_MAX_TOKENS=4000
USE_GROQ_VLM=true

PLANNER_MODEL=accounts/fireworks/models/qwen3p7-plus
CRITIC_MODEL=accounts/fireworks/models/qwen3p7-plus
SYNTHESIZER_MODEL=accounts/fireworks/models/qwen3p7-plus

# Embeddings — must match DENSE_DIM below.
EMBEDDING_MODEL=accounts/fireworks/models/qwen3-embedding-8b
EMBEDDING_TIMEOUT_S=60
EMBEDDING_BATCH_SIZE=32

# Reranker — one batched /v1/rerank call per subquery returns sorted scores.
RERANKER_MODEL=accounts/fireworks/models/qwen3-reranker-8b
RERANKER_DOC_MAX_CHARS=2000
RERANKER_TIMEOUT_S=60

# VLM extraction for infographics / charts / dashboard cards. Runs at
# ingestion — crops the page at every Chandra `Image` bbox and asks a vision
# model to transcribe the data. DECORATIVE-only regions (logos, banners) are
# dropped. Set ENABLE_VLM_EXTRACTION=false to skip and save cost.
ENABLE_VLM_EXTRACTION=true
VLM_MODEL=accounts/fireworks/models/qwen3p7-plus
VLM_CONCURRENCY=4
VLM_MAX_TOKENS=16000

# Table VLM verifier — MANDATORY visual verification of every text-extracted
# cell. Chandra's markdown flattener silently collapses multi-row / spanning
# headers (e.g. [Male | Female | Others] over [Number | Median]), which
# shifts column labels without lowering the text extractor's stated
# confidence. So we verify EVERY cell against the cropped table image
# rather than trusting `confidence=high`. Fans out concurrently, bounded by
# VLM_CONCURRENCY. Set to false to skip and save cost (at the risk of
# shifted-header bugs going undetected).
ENABLE_TABLE_VLM_VERIFY=true

# Table VLM extract-from-unfound — sends the cropped table image to the VLM
# when the TEXT extractor gave up on a target cell (couldn't find it in the
# markdown table). Catches cases where Chandra's markdown table parsing was
# too mangled for the text extractor to work but the visual table is still
# readable. Higher cost per query than verify because it fires on every
# unfound target × up to 2 candidate table chunks.
ENABLE_TABLE_VLM_EXTRACT_UNFOUND=true

# ════════════════════════════════════════════════════════════════════════════
# Composite extraction — the parallel wing to Table extraction. Chandra puts
# most report content (prose, lists, infographic-extracted values, named
# rosters, callout numbers) into `Composite`-labelled chunks. For every
# factual_lookup subquery we fire BOTH the Table wing (structured markdown
# tables) AND the Composite wing (LLM extraction over prose/list chunks)
# in parallel. Composite carries the majority of factual answers for
# non-BRSR reports. Single LLM call per subquery — no VLM.
# ════════════════════════════════════════════════════════════════════════════
ENABLE_COMPOSITE_EXTRACTION=true
# After rerank, cap the non-table chunks sent to the composite extractor.
COMPOSITE_EXTRACT_TOP_N=5

# Composite VLM verifier — mirror of ENABLE_TABLE_VLM_VERIFY but for the
# composite wing. Chandra loses the visual origin when it OCRs infographic
# text into Composite chunks, so we verify EVERY composite-extracted value
# against its source chunk's cropped bbox. Same VLM concurrency and merge
# rules as the table verifier. Set to false to skip if you don't want the
# extra VLM cost (each composite-produced value → 1 VLM call).
ENABLE_COMPOSITE_VLM_VERIFY=true

# Composite VLM extract-from-unfound — mirror of ENABLE_TABLE_VLM_EXTRACT_UNFOUND
# but for the composite wing. When the composite extractor gives up on a
# target, ask the VLM to try extracting the value from the top composite
# chunk images (independent extraction, no prior guess). Catches the case
# where the composite prose is ambiguous or the infographic-transcribed
# text has lost enough structure that the text extractor couldn't lock
# onto a value.
ENABLE_COMPOSITE_VLM_EXTRACT_UNFOUND=true

# Must match the embedding model's output dim.
# Qwen3-Embedding: 0.6B=1024, 4B=2560, 8B=4096.
DENSE_DIM=4096

# ════════════════════════════════════════════════════════════════════════════
# Chandra OCR (Modal). Should end in /ocr_page (per-page endpoint).
# ════════════════════════════════════════════════════════════════════════════
CHANDRA_OCR_URL=https://vineethrengaraj538
CHANDRA_OCR_TIMEOUT_S=600
# Match Modal's @concurrent(max_inputs=...) and vLLM's max_num_seqs.
CHANDRA_PAGE_CONCURRENCY=96

# ════════════════════════════════════════════════════════════════════════════
# Qdrant — pick ONE of the three modes (priority order if multiple set):
# 1. Local file store (no Docker, persists across restarts) — DEFAULT
# 2. Pure in-memory (fastest, lost on exit)
# 3. Real Qdrant server (Docker / cloud)
# ════════════════════════════════════════════════════════════════════════════
QDRANT_LOCAL_PATH=./data/qdrant_local
# QDRANT_IN_MEMORY=true
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ════════════════════════════════════════════════════════════════════════════
# Retrieval tuning
# ════════════════════════════════════════════════════════════════════════════
TOP_K_DENSE=30
TOP_K_SPARSE=30
TOP_K_RERANK=10
MAX_CRITIC_ITERATIONS=2
ENABLE_HYDE=false
